{
  "expo": {
    "name": "תרו",
    "slug": "sync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sync",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "il.co.sync.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "אנחנו צריכים את המיקום שלך כדי לאמת שאתה נמצא ברשות המקומית הרלוונטית להצבעה.",
        "NSLocationAlwaysUsageDescription": "אנחנו צריכים את המיקום שלך כדי לאמת שאתה נמצא ברשות המקומית הרלוונטית להצבעה."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "il.co.sync.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "אנחנו צריכים את המיקום שלך כדי לאמת שאתה נמצא ברשות המקומית הרלוונטית להצבעה."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB",
          "defaultChannel": "verification",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d36014d1-969a-445f-9f92-109ab2f0f201"
      }
    },
    "owner": "saharbarak"
  }
}
